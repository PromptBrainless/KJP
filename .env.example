# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ICD_CLIENT_ID & ICD_CLIENT_SECRET: For the World Health Organization (WHO) ICD-11 live REST API search.
# Users can get these credentials under the ICD API Portal and add them to the secrets panel.
ICD_CLIENT_ID=MY_ICD_CLIENT_ID
ICD_CLIENT_SECRET=MY_ICD_CLIENT_SECRET

